{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ParadoxDesignSystem foundation tokens. Source of truth for both Figma and Swift. Edit via Figma Variables export, then run `swift run generate-tokens`.",
  "color": {
    "background": {
      "primary":   { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#0A0A0F" } },
      "secondary": { "$type": "color", "$value": { "light": "#F7F7F8", "dark": "#101015" } },
      "tertiary":  { "$type": "color", "$value": { "light": "#EFEFF1", "dark": "#16161C" } },
      "elevated":  { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#1C1C24" } }
    },
    "surface": {
      "primary":   { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#15151B" } },
      "secondary": { "$type": "color", "$value": { "light": "#F4F4F6", "dark": "#1B1B22" } },
      "raised":    { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#22222B" } },
      "overlay":   { "$type": "color", "$value": { "light": "#00000066", "dark": "#000000A8" } }
    },
    "text": {
      "primary":   { "$type": "color", "$value": { "light": "#0B0B10", "dark": "#F5F5F7" } },
      "secondary": { "$type": "color", "$value": { "light": "#41414A", "dark": "#C7C7D1" } },
      "tertiary":  { "$type": "color", "$value": { "light": "#73737E", "dark": "#8F8F9A" } },
      "inverse":   { "$type": "color", "$value": { "light": "#FFFFFF", "dark": "#0B0B10" } },
      "link":      { "$type": "color", "$value": { "light": "#5562EA", "dark": "#8A93F5" } },
      "disabled":  { "$type": "color", "$value": { "light": "#B8B8C0", "dark": "#54545E" } }
    },
    "border": {
      "subtle":  { "$type": "color", "$value": { "light": "#ECECEF", "dark": "#1F1F27" } },
      "default": { "$type": "color", "$value": { "light": "#DCDCE1", "dark": "#2A2A33" } },
      "strong":  { "$type": "color", "$value": { "light": "#B8B8C0", "dark": "#3D3D48" } },
      "focus":   { "$type": "color", "$value": { "light": "#5562EA", "dark": "#8A93F5" } }
    },
    "status": {
      "success": { "$type": "color", "$value": { "light": "#1F9D55", "dark": "#3DD68A" } },
      "warning": { "$type": "color", "$value": { "light": "#C77700", "dark": "#F2B045" } },
      "error":   { "$type": "color", "$value": { "light": "#D7363B", "dark": "#FF6B6F" } },
      "info":    { "$type": "color", "$value": { "light": "#0B79D0", "dark": "#5BB8FF" } }
    },
    "accent": {
      "primary":        { "$type": "color", "$value": { "light": "#5562EA", "dark": "#7B86F2" } },
      "primaryPressed": { "$type": "color", "$value": { "light": "#4450C8", "dark": "#5F6BE0" } },
      "primarySubtle":  { "$type": "color", "$value": { "light": "#EEF0FE", "dark": "#1F2240" } }
    }
  },
  "spacing": {
    "xxs":   { "$type": "dimension", "$value": 2 },
    "xs":    { "$type": "dimension", "$value": 4 },
    "sm":    { "$type": "dimension", "$value": 8 },
    "md":    { "$type": "dimension", "$value": 12 },
    "lg":    { "$type": "dimension", "$value": 16 },
    "xl":    { "$type": "dimension", "$value": 24 },
    "xxl":   { "$type": "dimension", "$value": 32 },
    "xxxl":  { "$type": "dimension", "$value": 48 },
    "xxxxl": { "$type": "dimension", "$value": 64 }
  },
  "radius": {
    "xs":   { "$type": "dimension", "$value": 4 },
    "sm":   { "$type": "dimension", "$value": 6 },
    "md":   { "$type": "dimension", "$value": 8 },
    "lg":   { "$type": "dimension", "$value": 12 },
    "xl":   { "$type": "dimension", "$value": 16 },
    "xxl":  { "$type": "dimension", "$value": 24 },
    "pill": { "$type": "dimension", "$value": 9999 }
  }
}
